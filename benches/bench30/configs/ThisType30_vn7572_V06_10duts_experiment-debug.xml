<!--      										         Clock															  -->
<!-- *********************************************************************************************************************-->    
	<EventSource>
		<Name> Idle </Name>
		<Class> RC_CIdle </Class>
	</EventSource>
	<EventSource>
		<Name> SysClock </Name>
		<Class> RC_CSysClock </Class>
		<Config>
			<Attribute>
				<TimerPeriod_ms>30</TimerPeriod_ms>
			</Attribute>
		</Config>
	</EventSource>

	<EventSource>
		<Name>SysClock_DMM</Name>
		<Class>RC_CSysClock</Class>
		<Config>
			<Attribute>
				<TimerPeriod_ms>25</TimerPeriod_ms>
			</Attribute>
		</Config>
	</EventSource>

	<EventSource>
		<Name> SysClock_CAN </Name>
		<Class> RC_CSysClock </Class>
		<Config>
			<Attribute>
				<TimerPeriod_ms>4</TimerPeriod_ms>
			</Attribute>
		</Config>
	</EventSource>

	<EventSource>
		<Name> SysClock_PS </Name>
		<Class> RC_CSysClock </Class>
		<Config>
			<Attribute>
				<TimerPeriod_ms>100</TimerPeriod_ms>
			</Attribute>
		</Config>
	</EventSource>

